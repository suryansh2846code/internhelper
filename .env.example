# Internshala credentials
INTERNSHALA_EMAIL=your@email.com
INTERNSHALA_PASSWORD=yourpassword

# LLM provider: anthropic | openai | groq | local
LLM_PROVIDER=anthropic

# API keys (only the one matching LLM_PROVIDER is needed)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# Local model config (used when LLM_PROVIDER=local)
LOCAL_MODEL_PATH=./models/my_model
LOCAL_MODEL_TYPE=huggingface   # huggingface | ollama | custom

# Resume path (txt or pdf)
RESUME_PATH=./data/resume.txt
